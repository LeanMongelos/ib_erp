{
  "name": "ibiomedica",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-start.js",
    "dev:fast": "node scripts/dev-fast.js",
    "dev:status": "node scripts/dev-status.js",
    "dev:up": "node scripts/dev-up.js",
    "dev:clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\" && prisma generate && next dev",
    "dev:reset": "node scripts/dev-reset.js",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "smoke": "tsx --env-file=.env scripts/e2e-smoke.ts",
    "smoke:http": "node scripts/e2e-smoke.mjs",
    "test:plantillas": "tsx scripts/test-plantillas-parity.ts",
    "integridad:prod": "tsx --env-file=.env scripts/integridad-prod.ts",
    "test:validaciones": "tsx scripts/test-validar-sucursales.ts && tsx scripts/test-validar-sucursal-equipo.ts && tsx scripts/test-schemas-documentos.ts && tsx scripts/test-validar-moneda-documento.ts && tsx scripts/test-calcular-totales-presupuesto.ts && tsx scripts/test-validar-embudo.ts && tsx scripts/test-validar-repuestos-ot.ts && tsx scripts/test-schema-n8n-ot.ts && tsx scripts/test-schema-n8n-crm.ts",
    "test:invariants": "tsx scripts/test-plantillas-parity.ts && tsx scripts/test-validar-sucursales.ts && tsx scripts/test-validar-sucursal-equipo.ts && tsx scripts/test-schemas-documentos.ts && tsx scripts/test-validar-moneda-documento.ts && tsx scripts/test-calcular-totales-presupuesto.ts && tsx scripts/test-validar-embudo.ts && tsx scripts/test-validar-repuestos-ot.ts && tsx scripts/test-schema-n8n-ot.ts && tsx scripts/test-schema-n8n-crm.ts",
    "e2e": "tsx --env-file=.env scripts/e2e-revision.ts",
    "e2e:all": "tsx --env-file=.env scripts/e2e-smoke.ts && tsx --env-file=.env scripts/e2e-revision.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "worker:afip": "tsx --env-file=.env worker/afip-worker.ts",
    "worker:crm-email": "tsx --env-file=.env worker/crm-email-worker.ts",
    "worker:crm-graph": "tsx --env-file=.env worker/crm-graph-worker.ts",
    "worker:cobranzas": "tsx --env-file=.env worker/cobranzas-vencimientos-worker.ts",
    "logs:purge": "tsx --env-file=.env scripts/purge-system-logs.ts",
    "icons:generate": "node scripts/generate-favicons.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-progress": "^1.1.10",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@react-pdf/renderer": "^4.5.1",
    "@types/qrcode": "^1.5.6",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.79.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "imapflow": "^1.4.2",
    "ioredis": "^5.11.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.21.0",
    "next": "14.2.35",
    "next-auth": "^4.24.14",
    "nodemailer": "^7.0.13",
    "pg": "^8.22.0",
    "puppeteer": "^25.1.0",
    "qrcode": "^1.5.4",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.80.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8",
    "prisma": "^7.8.0",
    "sharp": "^0.35.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5"
  },
  "allowScripts": {
    "prisma@7.8.0": true,
    "@prisma/engines@7.8.0": true,
    "esbuild@0.28.1": true,
    "ssh2@1.17.0": true
  }
}
