// Schema Prisma — Sistema ERP Ingeniería Biomédica
// Modelos: Usuario, Cliente, Equipo, OrdenTrabajo, Factura, Inventario

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============ ENUMS ============

enum Rol {
  ADMIN
  TECNICO
  VENTAS
  FACTURACION
}

enum TipoCliente {
  HOSPITAL
  CLINICA
  CONSULTORIO
  SANATORIO
  ORGANISMO_PUBLICO
  OTRO
}

enum EstadoEquipo {
  ACTIVO
  EN_REPARACION
  BAJA
}

enum TipoEventoTracking {
  RECEPCION
  DEPOSITO
  EN_TRANSITO
  INSTALADO
  EN_SERVICIO
  RETIRO
  BAJA
}

enum TipoComponenteEquipo {
  BATERIA
  FILTRO
  CALIBRACION
  SENSOR
  OTRO
}

enum TipoArticuloInventario {
  REPUESTO
  CONSUMIBLE
  ACCESORIO
  BATERIA
  EQUIPO
}

enum TipoItemKitEquipo {
  ACCESORIO_ESPECIFICO
  ACCESORIO_GENERICO
  BATERIA
  COMPONENTE
  REPUESTO_INCLUIDO
}

enum OrigenEquipo {
  VENTA
  EXTERNO
  MANUAL_ST
}

enum TipoDeposito {
  DEPOSITO
  SHOWROOM
  CAJA
  OTRO
}

enum ModoTrazabilidad {
  NINGUNA
  SERIE
  LOTE
  SERIE_Y_LOTE
}

enum EstadoInventarioUnidad {
  EN_STOCK
  RESERVADO
  VENDIDO
  BAJA
}

enum TipoOT {
  CORRECTIVO
  PREVENTIVO
  INSTALACION
  CALIBRACION
  GARANTIA
}

enum TipoEntradaHistoriaClinica {
  OT
  PREVENTIVO
  NOTA
  INSTALACION
  COMPONENTE
  TRACKING
  CAMBIO_ESTADO
}

enum EstadoOT {
  ABIERTA
  EN_PROCESO
  CERRADA
  VENCIDA
  CANCELADA
}

enum Prioridad {
  BAJA
  NORMAL
  ALTA
  URGENTE
}

enum TipoFactura {
  A
  B
  C
}

enum OrigenProveedor {
  NACIONAL
  IMPORTADO
}

enum TipoCompraProveedor {
  REMITO    // equipos / stock (factura remito)
  CONCEPTOS // gastos, sin stock
  AMBOS
}

enum EstadoFactura {
  BORRADOR
  PENDIENTE       // legado: pendiente de cobro (pre-AFIP)
  PENDIENTE_CAE   // confirmada, esperando CAE de AFIP
  EMITIDA         // CAE obtenido — comprobante fiscal válido
  RECHAZADA       // AFIP rechazó
  PAGADA
  VENCIDA
  ANULADA
}

enum TipoPlantilla {
  FACTURA
  PRESUPUESTO
  REMITO
  NOTA_CREDITO
  NOTA_DEBITO
}

enum EstadoPresupuesto {
  BORRADOR
  ENVIADO
  APROBADO
  RECHAZADO
  VENCIDO
  CONVERTIDO
}

enum MedioPago {
  TRANSFERENCIA
  EFECTIVO
  CHEQUE
  TARJETA
  OTRO
}

enum EstadoVencimientoCobranza {
  PENDIENTE
  AVISO_ENVIADO
  COBRADO
  ANULADO
}

enum EstadoChequeCobranza {
  EN_CARTERA
  DEPOSITADO
  RECHAZADO
  ANULADO
}

enum EstadoOrdenCompra {
  BORRADOR
  PENDIENTE_APROBACION
  APROBADA
  RECHAZADA
  ENVIADA // legado: equivalente operativo a APROBADA
  PARCIAL
  RECIBIDA
  CANCELADA
}

enum TipoEventoOC {
  OC_CREADA
  OC_ENVIADA_APROBACION
  OC_REENVIADA
  OC_APROBADA
  OC_RECHAZADA
  OC_RECEPCION_PARCIAL
  OC_RECEPCION_COMPLETA
  OC_FC_REGISTRADA
  OC_FC_ANULADA
  OC_PAGO_PARCIAL
  OC_PAGO_COMPLETO
  OC_CANCELADA
}

enum TipoNotificacionOC {
  OC_PENDIENTE_APROBACION
  OC_APROBADA
  OC_RECHAZADA
}

enum ClasificacionOrigenOC {
  REPUESTO_OT
  STOCK_REPOSICION
  EQUIPO_VENTA
  SHOWROOM_MUESTRA
  GASTO_EDILICIO
  ALQUILER
  SERVICIO
  OTRO
}

enum TipoFacturaCompra {
  REMITO
  CONCEPTOS
}

enum EstadoFacturaCompra {
  BORRADOR
  REGISTRADA
  ANULADA
}

enum EstadoPagoProveedor {
  REGISTRADO
  ANULADO
}

enum EstadoChequeEmitido {
  EMITIDO
  DEBITADO
  ANULADO
}

enum TipoListaPrecios {
  MINORISTA
  MAYORISTA
  INSTITUCIONAL
  PROMOCION
  ESPECIAL
}

// ============ MODELOS ============

model Usuario {
  id           String    @id @default(cuid())
  nombre       String
  email        String    @unique
  password     String
  rol          Rol       @default(TECNICO) // legado: rol principal. La autorización real usa `roles` (RBAC).
  telefono     String?
  avatarUrl    String?
  activo               Boolean   @default(true)
  exigirCambioPassword Boolean   @default(false)
  ultimoAcceso         DateTime?
  creadoEn             DateTime  @default(now())

  ots   OrdenTrabajo[]
  roles UsuarioRol[]
  presupuestosVendidos Presupuesto[]
  mantenimientosAsignados PlanMantenimiento[]
  eventosTracking EventoTracking[]
  conversacionesAsignadas ConversacionCRM[]
  mensajesCRM             MensajeCRM[]
  equiposInstalados       Equipo[] @relation("EquipoInstaladoPor")
  entradasHistoriaClinica HistoriaClinicaEntrada[]
  historialEmbudo         HistorialEmbudo[]
  pagosConciliados        Pago[] @relation("PagosConciliados")
  movimientosTesoreriaCreados     MovimientoTesoreria[] @relation("MovimientosTesoreriaCreados")
  movimientosTesoreriaConciliados MovimientoTesoreria[] @relation("MovimientosTesoreriaConciliados")
  ordenesCompraCreadas            OrdenCompra[] @relation("OcCreador")
  ordenesCompraSolicitadas        OrdenCompra[] @relation("OcSolicitante")
  ordenesCompraAprobadas          OrdenCompra[] @relation("OcAprobador")
  ordenesCompraRechazadas         OrdenCompra[] @relation("OcRechazador")
  facturasCompraCreadas           FacturaCompra[] @relation("FcCompraCreador")
  pagosProveedorCreados           PagoProveedor[] @relation("PagoProveedorCreador")
  alertasCompraDismiss            AlertaCompraDismiss[]
  eventosOrdenCompra              EventoOrdenCompra[]
  notificacionesUsuario           NotificacionUsuario[]

  @@map("usuarios")
}

// ============ RBAC ============

model RolRBAC {
  id       String       @id @default(cuid())
  clave    String       @unique // SUPERADMIN, GERENTE, VENTAS, ...
  nombre   String
  sistema  Boolean      @default(false) // roles base que no se pueden borrar
  creadoEn DateTime     @default(now())

  usuarios UsuarioRol[]
  permisos RolPermiso[]

  @@map("roles")
}

model Permiso {
  id          String       @id @default(cuid())
  clave       String       @unique // "facturas.emit_afip"
  modulo      String
  descripcion String

  roles RolPermiso[]

  @@map("permisos")
}

model UsuarioRol {
  usuarioId String
  rolId     String

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  rol     RolRBAC @relation(fields: [rolId], references: [id], onDelete: Cascade)

  @@id([usuarioId, rolId])
  @@map("usuario_roles")
}

model RolPermiso {
  rolId     String
  permisoId String

  rol     RolRBAC @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso Permiso @relation(fields: [permisoId], references: [id], onDelete: Cascade)

  @@id([rolId, permisoId])
  @@map("rol_permisos")
}

// ============ EMISORES (multi-CUIT, carga manual) ============

enum AmbienteAfip {
  HOMOLOGACION
  PRODUCCION
}

model Emisor {
  id                String       @id @default(cuid())
  razonSocial       String
  cuit              String       @unique
  condicionIva      String       @default("Responsable Inscripto")
  ingresosBrutos    String?
  inicioActividades DateTime?
  domicilio         String?
  ciudad            String?
  telefono          String?
  email             String?
  // Credenciales AFIP (rutas a archivos cifrados en el storage; nunca el contenido en claro)
  certificadoPath   String?
  clavePrivadaPath  String?
  certificadoAlias  String?
  ambiente          AmbienteAfip @default(HOMOLOGACION)
  puntoVenta        Int          @default(1)
  predeterminado    Boolean      @default(false)
  activo            Boolean      @default(true)
  creadoEn          DateTime     @default(now())

  facturas     Factura[]
  presupuestos Presupuesto[]

  @@map("emisores")
}

// ============ AUDITORÍA ============

model AuditLog {
  id        String   @id @default(cuid())
  usuarioId String?
  accion    String // "usuario.create", "emisor.update", ...
  entidad   String
  entidadId String?
  antes     Json?
  despues   Json?
  ip        String?
  fecha     DateTime @default(now())

  @@index([entidad, entidadId])
  @@index([usuarioId])
  @@index([fecha])
  @@map("audit_logs")
}

enum NivelLog {
  ERROR
  WARN
  INFO
}

model SystemLog {
  id        String   @id @default(cuid())
  nivel     NivelLog @default(ERROR)
  origen    String // api, worker-afip, worker-crm, page, etc.
  ruta      String?
  metodo    String?
  mensaje   String
  stack     String?
  usuarioId String?
  ip        String?
  metadata  Json?
  fecha     DateTime @default(now())

  @@index([fecha])
  @@index([nivel])
  @@index([origen])
  @@index([usuarioId])
  @@map("system_logs")
}

model Cliente {
  id        String      @id @default(cuid())
  nombre    String
  tipo      TipoCliente
  cuit      String?
  direccion String?
  ciudad    String?
  telefono  String?
  email     String?
  contacto  String?
  activo    Boolean     @default(true)
  creadoEn  DateTime    @default(now())

  // ---- Ficha 360°: datos fiscales y comerciales (Fase 2) ----
  condicionIva  String? // Responsable Inscripto, Monotributo, Exento, Consumidor Final
  condicionPago String? // Contado, 30 días, 60 días, etc.
  limiteCredito Float?  // límite de crédito en ARS (null = sin límite definido)
  segmento      String? // segmento comercial manual (override del automático): VIP, Recurrente, etc.
  sitioWeb      String?
  notas         String?
  lat           Float?  // geolocalización sede (Fase 8)
  lng           Float?

  alicuotaIvaId String?
  alicuotaIva   AlicuotaIva? @relation(fields: [alicuotaIvaId], references: [id])

  // Listas de precios comerciales (Fase 1)
  listaPreciosId  String?
  listaPrecios    ListaPrecios? @relation(fields: [listaPreciosId], references: [id])
  esMayorista     Boolean       @default(false)
  monedaPreferida String?

  equipos      Equipo[]
  ots          OrdenTrabajo[]
  facturas     Factura[]
  presupuestos Presupuesto[]
  pagos        Pago[]
  cheques      ChequeCobranza[]
  contactos    ContactoCliente[]
  conversaciones ConversacionCRM[]
  negociosEmbudo NegocioEmbudo[]
  sucursales   ClienteSucursal[]
  ordenesCompra  OrdenCompra[]

  @@map("clientes")
}

model ClienteSucursal {
  id        String   @id @default(cuid())
  clienteId String
  nombre    String
  direccion String?
  numero    String?
  ciudad    String?
  lat       Float?
  lng       Float?
  activo    Boolean  @default(true)
  notas     String?
  creadoEn  DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  equipos Equipo[]
  itemsFacturaInstalacion ItemFactura[]

  @@index([clienteId])
  @@map("clientes_sucursales")
}

// Contactos adicionales del cliente (multi-contacto de la ficha 360°)
model ContactoCliente {
  id        String   @id @default(cuid())
  clienteId String
  nombre    String
  cargo     String?
  email     String?
  telefono  String?
  principal Boolean  @default(false)
  creadoEn  DateTime @default(now())

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@map("contactos_cliente")
}

model Equipo {
  id            String       @id @default(cuid())
  nombre        String
  marca         String?
  modelo        String?
  modeloExacto  String?
  numeroSerie   String?      @unique
  codigoInterno String?
  firmwareVersion  String?
  softwareVersion String?
  garantiaHasta DateTime?
  estado        EstadoEquipo @default(ACTIVO)
  clienteId     String
  ubicacionLat  Float?
  ubicacionLng  Float?
  direccionUbicacion String?
  fechaInstalacion   DateTime?
  servicioInstalacion String?
  pisoSala           String?
  contactoResponsable String?
  notasTecnicas      String?
  proveedorOrigenId  String?
  referenciaCompra   String?
  instaladoPorUsuarioId String?
  sucursalId            String?
  origen        OrigenEquipo @default(VENTA)
  inventarioId  String?
  creadoEn      DateTime     @default(now())

  cliente  Cliente             @relation(fields: [clienteId], references: [id])
  inventario Inventario?       @relation(fields: [inventarioId], references: [id])
  unidadInventario InventarioUnidad? @relation("UnidadEquipo")
  sucursal ClienteSucursal?    @relation(fields: [sucursalId], references: [id])
  proveedorOrigen Proveedor?   @relation(fields: [proveedorOrigenId], references: [id])
  instaladoPor    Usuario?     @relation("EquipoInstaladoPor", fields: [instaladoPorUsuarioId], references: [id])
  ots      OrdenTrabajo[]
  planes   PlanMantenimiento[]
  eventos  EventoTracking[]
  accesorios  EquipoAccesorio[]
  componentes EquipoComponente[]
  entradasHistoria HistoriaClinicaEntrada[]
  itemFacturaOrigen ItemFactura? @relation("FacturaItemEquipo")

  @@index([clienteId])
  @@index([sucursalId])
  @@map("equipos")
}

model EquipoAccesorio {
  id           String  @id @default(cuid())
  equipoId     String
  nombre       String
  inventarioId String?
  cantidad     Int     @default(1)
  obligatorio  Boolean @default(true)
  notas        String?
  creadoEn     DateTime @default(now())

  equipo     Equipo      @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  inventario Inventario? @relation(fields: [inventarioId], references: [id])

  @@index([equipoId])
  @@map("equipo_accesorios")
}

model EquipoComponente {
  id              String               @id @default(cuid())
  equipoId        String
  tipo            TipoComponenteEquipo @default(OTRO)
  descripcion     String
  numeroSerie     String?
  instaladoEn     DateTime?
  venceEn         DateTime?
  alertaDiasAntes Int                  @default(30)
  activo          Boolean              @default(true)
  notas           String?
  creadoEn        DateTime             @default(now())

  equipo Equipo @relation(fields: [equipoId], references: [id], onDelete: Cascade)

  @@index([equipoId])
  @@index([venceEn])
  @@map("equipo_componentes")
}

model HistoriaClinicaEntrada {
  id           String                   @id @default(cuid())
  equipoId     String
  tipo         TipoEntradaHistoriaClinica
  titulo       String
  contenido    String?
  referenciaId String?
  usuarioId    String?
  fecha        DateTime                 @default(now())
  creadoEn     DateTime                 @default(now())

  equipo  Equipo   @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([equipoId, fecha])
  @@map("historia_clinica_entradas")
}

model OrdenTrabajo {
  id            String    @id @default(cuid())
  numero        String    @unique
  descripcion   String
  diagnostico   String?
  tipo          TipoOT    @default(CORRECTIVO)
  estado        EstadoOT  @default(ABIERTA)
  prioridad     Prioridad @default(NORMAL)
  slaHoras      Int       @default(48)
  fechaApertura DateTime  @default(now())
  fechaCierre   DateTime?
  slaVence      DateTime
  clienteId     String
  equipoId      String?
  tecnicoId     String?
  creadoEn      DateTime  @default(now())

  cliente   Cliente       @relation(fields: [clienteId], references: [id])
  equipo    Equipo?       @relation(fields: [equipoId], references: [id])
  tecnico   Usuario?      @relation(fields: [tecnicoId], references: [id])
  repuestos RepuestoOT[]
  historial HistorialOT[]
  factura   Factura?
  presupuestos Presupuesto[]
  ordenesCompra OrdenCompra[]
  eventosTracking EventoTracking[]

  @@map("ordenes_trabajo")
}

model RepuestoOT {
  id          String  @id @default(cuid())
  descripcion String
  cantidad    Int
  precioUnit  Float
  otId        String
  inventarioId String?

  ot         OrdenTrabajo @relation(fields: [otId], references: [id])
  inventario Inventario?  @relation(fields: [inventarioId], references: [id])

  @@map("repuestos_ot")
}

model HistorialOT {
  id       String   @id @default(cuid())
  estado   EstadoOT
  nota     String?
  otId     String
  creadoEn DateTime @default(now())

  ot OrdenTrabajo @relation(fields: [otId], references: [id])

  @@map("historial_ot")
}

// ============ FISCAL / IVA ============

model AlicuotaIva {
  id               String   @id @default(cuid())
  codigo           String   @unique
  nombre           String
  porcentaje       Float
  activo           Boolean  @default(true)
  esPredeterminada Boolean  @default(false)
  creadoEn         DateTime @default(now())

  clientes   Cliente[]
  inventario Inventario[]
  condicionesIva CondicionIvaCat[]

  @@map("alicuotas_iva")
}

// ============ CONTABILIDAD / FISCAL ARGENTINA ============

model ConfiguracionContable {
  id                        String   @id @default("default")
  monedaFuncional           String   @default("ARS")
  cotizacionUsdManual       Float?
  usaCotizacionBna          Boolean  @default(true)
  agenteRetencionGanancias  Boolean  @default(false)
  agenteRetencionIva        Boolean  @default(false)
  agentePercepcionIva       Boolean  @default(false)
  agenteRetencionIibb        Boolean  @default(false)
  agentePercepcionIibb      Boolean  @default(false)
  inscriptoIibb             Boolean  @default(false)
  numeroInscripcionIibb     String?
  convenioMultilateralIibb  Boolean  @default(false)
  libroIvaDigital           Boolean  @default(true)
  periodicidadIva           String   @default("MENSUAL") // MENSUAL | BIMESTRAL
  cierreIvaDia              Int      @default(20)
  ejercicioActivoId         String?  @unique
  notasContador             String?
  actualizadoEn             DateTime @updatedAt

  ejercicioActivo EjercicioContable? @relation(fields: [ejercicioActivoId], references: [id])

  @@map("configuracion_contable")
}

/// Correlativos configurables para migración (presupuesto, factura interna, remito).
model SecuenciaNumeracion {
  id            String   @id @default(cuid())
  clave         String   @unique
  etiqueta      String
  tipo          String
  subtipo       String?
  anio          Int?
  prefijo       String
  padding       Int      @default(4)
  /// Próximo número a asignar al crear un comprobante.
  proximoNumero Int      @default(1)
  actualizadoEn DateTime @updatedAt

  @@map("secuencias_numeracion")
}

model CondicionIvaCat {
  id            String  @id @default(cuid())
  codigo        String  @unique
  nombre        String
  descripcion   String?
  alicuotaIvaId String?
  requiereCuit  Boolean @default(true)
  activo        Boolean @default(true)
  esDefault     Boolean @default(false)
  orden         Int     @default(0)

  alicuotaIva AlicuotaIva? @relation(fields: [alicuotaIvaId], references: [id])

  @@map("condiciones_iva_cat")
}

model JurisdiccionIibb {
  id                   String  @id @default(cuid())
  codigo               String  @unique
  nombre               String
  provincia            String
  alicuotaGeneral      Float?
  convenioMultilateral Boolean @default(false)
  activo               Boolean @default(true)

  regimenes RegimenImpositivo[]

  @@map("jurisdicciones_iibb")
}

model RegimenImpositivo {
  id                 String  @id @default(cuid())
  codigo             String  @unique
  nombre             String
  tipo               String // RET_GAN | RET_IVA | PERC_IVA | RET_IIBB | PERC_IIBB | RET_SUSS
  alicuota           Float
  minimoNoImponible  Float   @default(0)
  baseMinima         Float   @default(0)
  jurisdiccionIibbId String?
  activo             Boolean @default(true)

  jurisdiccion JurisdiccionIibb? @relation(fields: [jurisdiccionIibbId], references: [id])

  @@map("regimenes_impositivos")
}

model CondicionPagoCat {
  id              String  @id @default(cuid())
  codigo          String  @unique
  nombre          String
  diasPlazo       Int     @default(0)
  plazosCobranza  String? // ej. "30-60-90"
  activo          Boolean @default(true)
  esDefault       Boolean @default(false)

  @@map("condiciones_pago_cat")
}

model PlanCuenta {
  id               String  @id @default(cuid())
  codigo           String  @unique
  nombre           String
  tipo             String // ACTIVO | PASIVO | PATRIMONIO | INGRESO | EGRESO | ORDEN
  nivel            Int     @default(1)
  padreId          String?
  aceptaImputacion Boolean @default(true)
  activo           Boolean @default(true)

  padre PlanCuenta?  @relation("PlanCuentaArbol", fields: [padreId], references: [id])
  hijos PlanCuenta[] @relation("PlanCuentaArbol")
  cuentasTesoreria CuentaTesoreria[]

  @@map("plan_cuentas")
}

model EjercicioContable {
  id          String   @id @default(cuid())
  nombre      String
  anio        Int
  fechaInicio DateTime
  fechaFin    DateTime
  cerrado     Boolean  @default(false)
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  configActiva ConfiguracionContable?

  @@unique([anio])
  @@map("ejercicios_contables")
}

model TipoComprobanteAfip {
  id          String  @id @default(cuid())
  codigoAfip  Int     @unique
  letra       String
  descripcion String
  aplicaIva   Boolean @default(true)
  activo      Boolean @default(true)

  facturasCompra FacturaCompra[]

  @@map("tipos_comprobante_afip")
}

model TipoDocumentoAfip {
  id         String  @id @default(cuid())
  codigoAfip Int     @unique
  nombre     String
  activo     Boolean @default(true)

  @@map("tipos_documento_afip")
}

model Factura {
  id               String        @id @default(cuid())
  numero           String        @unique // número interno legible (ej. B-10001)
  tipo             TipoFactura
  estado           EstadoFactura @default(BORRADOR)
  fechaEmision     DateTime      @default(now())
  fechaVencimiento DateTime?
  fechaPago        DateTime? // fecha real de cobro (Fase 5)
  subtotal         Float
  iva              Float
  total            Float
  moneda           String        @default("ARS")
  cotizacionUsd    Float?
  bonificacionPct  Float         @default(0)
  alicuotaIvaPct   Float         @default(21)
  clienteId        String
  emisorId         String?
  plantillaId      String?
  presupuestoId    String?       @unique
  otId             String?       @unique
  condicionPago    String?
  observaciones    String?
  // AFIP / fiscal
  puntoVenta       Int?
  numeroAfip       Int? // número de comprobante en AFIP
  cae              String?
  caeVencimiento   DateTime?
  qrData           String? // JSON base64 para QR fiscal
  afipObservaciones String?
  concepto         Int           @default(1) // 1=Productos, 2=Servicios, 3=Ambos
  facturaOrigenId  String?       // nota de crédito → factura anulada
  creadoEn         DateTime      @default(now())

  cliente       Cliente            @relation(fields: [clienteId], references: [id])
  emisor        Emisor?            @relation(fields: [emisorId], references: [id])
  plantilla     PlantillaImpresion? @relation(fields: [plantillaId], references: [id])
  presupuesto   Presupuesto?       @relation(fields: [presupuestoId], references: [id])
  ot            OrdenTrabajo?      @relation(fields: [otId], references: [id])
  facturaOrigen Factura?           @relation("NotaCreditoOrigen", fields: [facturaOrigenId], references: [id])
  notasCredito  Factura[]          @relation("NotaCreditoOrigen")
  items         ItemFactura[]
  pagos         PagoFactura[]
  vencimientos  VencimientoCobranza[]

  @@index([fechaEmision])
  @@index([estado, fechaEmision])
  @@map("facturas")
}

model ItemFactura {
  id               String  @id @default(cuid())
  codigo           String?
  descripcion      String
  descripcionLarga String?
  fotoUrl          String?
  cantidad         Int
  precioUnit       Float
  bonificacionPct  Float   @default(0)
  alicuotaIvaPct   Float?
  subtotal         Float
  inventarioId     String?
  facturaId        String
  numeroSerie      String?
  proximoPreventivo DateTime?
  equipoGeneradoId String?  @unique
  sucursalInstalacionId String?
  inventarioUnidadId String? @unique

  inventario Inventario? @relation(fields: [inventarioId], references: [id])
  factura    Factura     @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  equipoGenerado Equipo? @relation("FacturaItemEquipo", fields: [equipoGeneradoId], references: [id])
  sucursalInstalacion ClienteSucursal? @relation(fields: [sucursalInstalacionId], references: [id])
  inventarioUnidad InventarioUnidad? @relation("UnidadVendida", fields: [inventarioUnidadId], references: [id])

  @@map("items_factura")
}

model Inventario {
  id          String   @id @default(cuid())
  nombre      String
  descripcion String?
  sku         String?  @unique
  tipoArticulo TipoArticuloInventario @default(REPUESTO)
  marca       String?
  modelo      String?
  esSerializado Boolean @default(false)
  requierePreventivo Boolean @default(false)
  intervaloPreventivoDias Int?
  modoTrazabilidad ModoTrazabilidad @default(NINGUNA)
  stock       Int      @default(0)
  stockMinimo Int      @default(5)
  stockMaximo Int?
  puntoPedido Int? // reorder point
  precioUnit  Float?
  moneda      String   @default("ARS")
  categoria   String?
  alicuotaIvaId String?
  fotoUrl     String?
  activo      Boolean  @default(true)
  creadoEn    DateTime @default(now())

  proveedores  ProveedorProducto[]
  itemsFactura ItemFactura[]
  movimientos  MovimientoStock[]
  itemsOC      ItemOrdenCompra[]
  plantillaOCItems PlantillaOCItem[]
  itemsFacturaCompra ItemFacturaCompra[]
  accesoriosEquipo EquipoAccesorio[]
  repuestosOT      RepuestoOT[]
  itemsPresupuesto ItemPresupuesto[]
  kitComoEquipo    InventarioKitItem[] @relation("KitEquipoPadre")
  kitComoIncluido  InventarioKitItem[] @relation("KitEquipoHijo")
  itemsListaPrecios ListaPreciosItem[]
  unidades         InventarioUnidad[]
  equipos          Equipo[]
  stockDepositos   StockDeposito[]

  alicuotaIva AlicuotaIva? @relation(fields: [alicuotaIvaId], references: [id])

  @@map("inventario")
}

model InventarioUnidad {
  id            String                 @id @default(cuid())
  inventarioId  String
  numeroSerie   String?
  lote          String?
  estado        EstadoInventarioUnidad @default(EN_STOCK)
  fechaIngreso  DateTime               @default(now())
  notas         String?
  equipoId      String?                @unique
  depositoId    String?
  ubicacionDetalle String?

  inventario           Inventario   @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  deposito             Deposito?    @relation(fields: [depositoId], references: [id])
  equipo               Equipo?      @relation("UnidadEquipo", fields: [equipoId], references: [id])
  itemFacturaReservado ItemFactura? @relation("UnidadVendida")

  @@unique([inventarioId, numeroSerie])
  @@index([inventarioId])
  @@index([inventarioId, estado])
  @@index([depositoId])
  @@map("inventario_unidades")
}

model ListaPrecios {
  id                 String           @id @default(cuid())
  codigo             String           @unique
  nombre             String
  tipo               TipoListaPrecios
  moneda             String           @default("ARS")
  ajusteGlobalPct    Float            @default(0) // negativo = descuento, positivo = recargo
  vigenciaDesde      DateTime?
  vigenciaHasta      DateTime?
  notas              String?
  activo             Boolean          @default(true)
  predeterminada     Boolean          @default(false)
  creadoEn           DateTime         @default(now())

  items    ListaPreciosItem[]
  clientes Cliente[]

  @@map("listas_precios")
}

model ListaPreciosItem {
  id              String    @id @default(cuid())
  listaPreciosId  String
  inventarioId    String
  precioUnit      Float
  bonificacionPct Float     @default(0)
  vigenciaDesde   DateTime?
  vigenciaHasta   DateTime?

  listaPrecios ListaPrecios @relation(fields: [listaPreciosId], references: [id], onDelete: Cascade)
  inventario   Inventario   @relation(fields: [inventarioId], references: [id])

  @@unique([listaPreciosId, inventarioId])
  @@map("lista_precios_items")
}

model InventarioKitItem {
  id                String            @id @default(cuid())
  inventarioPadreId String
  inventarioHijoId  String?
  nombre            String
  tipoItem          TipoItemKitEquipo
  tipoComponente    TipoComponenteEquipo?
  obligatorio       Boolean           @default(false)
  cantidad          Int               @default(1)
  mesesVencimiento  Int?
  notas             String?
  orden             Int               @default(0)

  padre Inventario  @relation("KitEquipoPadre", fields: [inventarioPadreId], references: [id], onDelete: Cascade)
  hijo  Inventario? @relation("KitEquipoHijo", fields: [inventarioHijoId], references: [id])

  @@index([inventarioPadreId])
  @@map("inventario_kit_items")
}

// ============ PROVEEDORES (Fase 2) ============

model Proveedor {
  id               String          @id @default(cuid())
  razonSocial      String
  cuit             String?
  condicionIva     String?
  rubro            String? // rubro / categoría comercial
  origen           OrigenProveedor     @default(NACIONAL)
  tipoCompra       TipoCompraProveedor @default(AMBOS)
  moneda           String              @default("ARS") // moneda habitual de operación
  email            String?
  telefono         String?
  sitioWeb         String?
  direccion        String?
  ciudad           String?
  marcas           String? // marcas / líneas que representa (texto libre)
  // Condiciones comerciales por defecto
  condicionPago    String? // Contado, 30/60/90 días, etc.
  financiacionPct  Float? // % de recargo (+) o descuento (-) financiero por defecto
  plazoEntregaDias Int? // lead time típico en días
  minimoCompra     Float? // mínimo de compra
  notas            String?
  activo           Boolean         @default(true)
  creadoEn         DateTime        @default(now())

  contactos   ContactoProveedor[]
  condiciones CondicionComercialProveedor[]
  productos   ProveedorProducto[]
  equiposOrigen Equipo[]
  ordenesCompra   OrdenCompra[]
  facturasCompra  FacturaCompra[]
  pagosProveedor  PagoProveedor[]
  chequesEmitidos ChequeEmitido[]
  plantillasOC    PlantillaOC[]

  @@map("proveedores")
}

// Contactos del proveedor (comercial, técnico, postventa…)
model ContactoProveedor {
  id          String   @id @default(cuid())
  proveedorId String
  nombre      String
  cargo       String? // comercial, técnico, postventa
  email       String?
  telefono    String?
  whatsapp    String?
  principal   Boolean  @default(false)
  creadoEn    DateTime @default(now())

  proveedor Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@index([proveedorId])
  @@map("contactos_proveedor")
}

// Condiciones de financiación por plazo (contado, 30d, 60d, cuotas…)
model CondicionComercialProveedor {
  id           String  @id @default(cuid())
  proveedorId  String
  descripcion  String // ej. "Contado", "30 días", "3 cuotas"
  plazoDias    Int     @default(0)
  recargoPct   Float   @default(0)
  descuentoPct Float   @default(0)

  proveedor Proveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)

  @@index([proveedorId])
  @@map("condiciones_proveedor")
}

// Lista de precios: producto provisto por un proveedor (con histórico por vigencia)
model ProveedorProducto {
  id             String   @id @default(cuid())
  proveedorId    String
  inventarioId   String? // vínculo opcional con un ítem del inventario
  nombreProducto String // nombre/descripción del producto que provee
  costo          Float
  bonificacionPct Float   @default(0)
  moneda         String   @default("ARS")
  leadTimeDias   Int?
  garantiaMeses  Int?
  vigenteDesde   DateTime @default(now())
  creadoEn       DateTime @default(now())

  proveedor  Proveedor   @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  inventario Inventario? @relation(fields: [inventarioId], references: [id])

  @@index([proveedorId])
  @@index([inventarioId])
  @@map("proveedor_productos")
}

// ============ PLANTILLAS DE IMPRESIÓN (Fase 3) ============

model PlantillaImpresion {
  id             String        @id @default(cuid())
  nombre         String
  tipo           TipoPlantilla
  config         Json // esquema JSON versionado (bloques, columnas, estilos)
  version        Int           @default(1)
  predeterminado Boolean       @default(false)
  activo         Boolean       @default(true)
  creadoEn       DateTime      @default(now())

  facturas     Factura[]
  presupuestos Presupuesto[]

  @@map("plantillas_impresion")
}

// ============ PRESUPUESTOS (Fase 3) ============

model Presupuesto {
  id              String            @id @default(cuid())
  numero          String            @unique
  estado          EstadoPresupuesto @default(BORRADOR)
  clienteId       String
  emisorId        String?
  plantillaId     String?
  vendedorId      String?
  condicionPago         String?
  tasaFinanciacionPct   Float             @default(0)
  interesFinanciacion   Float             @default(0)
  vigenciaDias          Int               @default(15)
  observaciones   String?
  formaPago       String?
  plazoEntrega    String?
  garantia        String?
  subtotal        Float
  iva             Float
  total           Float
  moneda          String            @default("ARS")
  cotizacionUsd   Float?
  bonificacionPct Float             @default(0)
  alicuotaIvaPct  Float             @default(21)
  fechaEmision    DateTime          @default(now())
  fechaVencimiento DateTime?
  creadoEn        DateTime          @default(now())
  otId            String?

  cliente   Cliente             @relation(fields: [clienteId], references: [id])
  emisor    Emisor?             @relation(fields: [emisorId], references: [id])
  plantilla PlantillaImpresion? @relation(fields: [plantillaId], references: [id])
  vendedor  Usuario?            @relation(fields: [vendedorId], references: [id])
  ot        OrdenTrabajo?       @relation(fields: [otId], references: [id])
  items     ItemPresupuesto[]
  factura   Factura?
  negociosEmbudo NegocioEmbudo[]
  ordenesCompra  OrdenCompra[]

  @@index([otId])
  @@map("presupuestos")
}

model ItemPresupuesto {
  id               String  @id @default(cuid())
  presupuestoId    String
  codigo           String?
  descripcion      String
  descripcionLarga String?
  fotoUrl          String?
  cantidad         Int
  precioUnit       Float
  bonificacionPct  Float   @default(0)
  alicuotaIvaPct   Float?
  subtotal         Float
  inventarioId     String?
  numeroSerie      String?
  proximoPreventivo DateTime?

  presupuesto Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)
  inventario  Inventario? @relation(fields: [inventarioId], references: [id])

  @@map("items_presupuesto")
}

// ============ COBRANZAS (Fase 5) ============

model Pago {
  id         String    @id @default(cuid())
  clienteId  String
  monto      Float
  medio      MedioPago @default(TRANSFERENCIA)
  fecha      DateTime  @default(now())
  referencia String?
  notas             String?
  anuladoEn         DateTime?
  conciliadoEn      DateTime?
  conciliadoPorId   String?
  cuentaTesoreriaId String?
  creadoEn          DateTime  @default(now())

  cliente         Cliente              @relation(fields: [clienteId], references: [id])
  conciliadoPor   Usuario?             @relation("PagosConciliados", fields: [conciliadoPorId], references: [id])
  cuentaTesoreria CuentaTesoreria?     @relation(fields: [cuentaTesoreriaId], references: [id])
  imputaciones    PagoFactura[]
  cheque          ChequeCobranza?
  movimientoTesoreria MovimientoTesoreria?

  @@index([anuladoEn])
  @@index([conciliadoEn])
  @@index([cuentaTesoreriaId])
  @@map("pagos")
}

model ChequeCobranza {
  id                    String                @id @default(cuid())
  pagoId                String                @unique
  clienteId             String
  numero                String
  banco                 String                @default("")
  titular               String?
  monto                 Float
  fechaRecepcion        DateTime              @default(now())
  fechaVencimiento      DateTime
  estado                EstadoChequeCobranza  @default(EN_CARTERA)
  fechaDeposito         DateTime?
  recordatorioEnviadoEn DateTime?
  notas                 String?
  creadoEn              DateTime              @default(now())
  actualizadoEn        DateTime              @updatedAt

  pago    Pago    @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  cliente Cliente @relation(fields: [clienteId], references: [id])

  @@unique([numero, banco])
  @@index([fechaVencimiento, estado])
  @@index([clienteId, estado])
  @@map("cheques_cobranza")
}

model PagoFactura {
  pagoId    String
  facturaId String
  monto     Float

  pago    Pago    @relation(fields: [pagoId], references: [id], onDelete: Cascade)
  factura Factura @relation(fields: [facturaId], references: [id])

  @@id([pagoId, facturaId])
  @@map("pago_facturas")
}

model VencimientoCobranza {
  id               String                    @id @default(cuid())
  facturaId        String
  numeroCuota      Int
  diasDesdeEmision Int
  fechaVencimiento DateTime
  monto            Float
  estado           EstadoVencimientoCobranza @default(PENDIENTE)
  avisoEnviadoEn   DateTime?
  cobradoEn        DateTime?
  creadoEn          DateTime                  @default(now())

  factura Factura @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  @@unique([facturaId, numeroCuota])
  @@index([fechaVencimiento, estado])
  @@map("vencimientos_cobranza")
}

// ============ TESORERÍA ============

enum TipoCuentaTesoreria {
  BANCO
  CAJA
}

enum TipoMovimientoTesoreria {
  SALDO_INICIAL
  INGRESO
  EGRESO
  AJUSTE
  TRANSFERENCIA
}

model CuentaTesoreria {
  id                  String              @id @default(cuid())
  nombre              String
  tipo                TipoCuentaTesoreria
  banco               String?
  cbu                 String?
  alias               String?
  moneda              String              @default("ARS")
  planCuentaId        String?
  activa              Boolean             @default(true)
  saldoInicialCargado Boolean             @default(false)
  predeterminada      Boolean             @default(false)
  creadoEn            DateTime            @default(now())
  actualizadoEn       DateTime            @updatedAt

  planCuenta      PlanCuenta?            @relation(fields: [planCuentaId], references: [id])
  movimientos     MovimientoTesoreria[]
  pagos           Pago[]
  pagosProveedor  PagoProveedor[]
  chequesEmitidos ChequeEmitido[]

  @@map("cuentas_tesoreria")
}

model MovimientoTesoreria {
  id                String                  @id @default(cuid())
  cuentaTesoreriaId String
  fecha             DateTime
  tipo              TipoMovimientoTesoreria
  monto             Float
  descripcion       String
  referencia        String?
  conciliadoEn      DateTime?
  conciliadoPorId   String?
  extractoRef       String?
  notaConciliacion  String?
  pagoId            String?                 @unique
  pagoProveedorId   String?                 @unique
  anuladoEn         DateTime?
  transferenciaId   String?
  creadoPorId       String
  creadoEn          DateTime                @default(now())

  cuentaTesoreria CuentaTesoreria @relation(fields: [cuentaTesoreriaId], references: [id])
  pago            Pago?           @relation(fields: [pagoId], references: [id])
  pagoProveedor   PagoProveedor?  @relation(fields: [pagoProveedorId], references: [id])
  chequeEmitido   ChequeEmitido?
  conciliadoPor   Usuario?        @relation("MovimientosTesoreriaConciliados", fields: [conciliadoPorId], references: [id])
  creadoPor       Usuario         @relation("MovimientosTesoreriaCreados", fields: [creadoPorId], references: [id])

  @@index([cuentaTesoreriaId, fecha])
  @@index([conciliadoEn])
  @@map("movimientos_tesoreria")
}

// ============ INVENTARIO AVANZADO (Fase 2 inv) ============

model Deposito {
  id       String  @id @default(cuid())
  nombre   String
  direccion String?
  tipo     TipoDeposito @default(DEPOSITO)
  activo   Boolean @default(true)
  creadoEn DateTime @default(now())

  movimientos      MovimientoStock[]
  stockDepositos   StockDeposito[]
  unidadesInventario InventarioUnidad[]
  ordenesCompraDestinoDefault OrdenCompra[] @relation("OcDepositoDefault")
  itemsOcDestino   ItemOrdenCompra[] @relation("ItemOcDepositoDestino")

  @@map("depositos")
}

model StockDeposito {
  id               String  @id @default(cuid())
  inventarioId     String
  depositoId       String
  cantidad         Int     @default(0)
  ubicacionDetalle String?

  inventario Inventario @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  deposito   Deposito   @relation(fields: [depositoId], references: [id])

  @@unique([inventarioId, depositoId])
  @@index([inventarioId])
  @@map("stock_depositos")
}

enum TipoMovimientoStock {
  ENTRADA
  SALIDA
  AJUSTE
  TRANSFERENCIA
}

model MovimientoStock {
  id           String             @id @default(cuid())
  inventarioId String
  depositoId   String?
  tipo         TipoMovimientoStock
  cantidad     Int
  stockAntes   Int
  stockDespues Int
  motivo       String?
  referencia   String? // OC-xxx, OT-xxx, etc.
  usuarioId    String?
  creadoEn     DateTime           @default(now())

  inventario Inventario @relation(fields: [inventarioId], references: [id])
  deposito   Deposito?  @relation(fields: [depositoId], references: [id])

  @@index([inventarioId])
  @@map("movimientos_stock")
}

// ============ ÓRDENES DE COMPRA (Fase 6) ============

model PlantillaOC {
  id                   String                @id @default(cuid())
  nombre               String
  clasificacionOrigen  ClasificacionOrigenOC
  proveedorId          String
  descripcionDefault   String?
  justificacionDefault String?
  moneda               String                @default("ARS")
  activa               Boolean               @default(true)
  recordatorioDiaMes   Int?
  creadoEn             DateTime              @default(now())

  proveedor     Proveedor         @relation(fields: [proveedorId], references: [id])
  items         PlantillaOCItem[]
  ordenesCompra OrdenCompra[]

  @@index([activa, clasificacionOrigen])
  @@map("plantillas_oc")
}

model PlantillaOCItem {
  id           String  @id @default(cuid())
  plantillaId  String
  descripcion  String
  concepto     String?
  cantidad     Int
  precioUnit   Float // precio neto unitario
  inventarioId String?

  plantilla  PlantillaOC @relation(fields: [plantillaId], references: [id], onDelete: Cascade)
  inventario Inventario? @relation(fields: [inventarioId], references: [id])

  @@map("plantillas_oc_items")
}

model OrdenCompra {
  id                    String            @id @default(cuid())
  numero                String            @unique
  proveedorId           String
  estado                EstadoOrdenCompra @default(BORRADOR)
  subtotal              Float             @default(0)
  total                 Float             @default(0)
  observaciones         String?
  fechaEmision          DateTime          @default(now())
  fechaEntrega          DateTime?
  ultimaRecepcionEn     DateTime?
  creadoEn              DateTime          @default(now())
  creadoPorId           String?
  solicitanteId         String?
  justificacion         String?
  clasificacionOrigen   ClasificacionOrigenOC?
  ordenTrabajoId        String?
  presupuestoId         String?
  clienteId             String?
  depositoDestinoDefaultId String?
  moneda                String            @default("ARS")
  cotizacionUsd         Float?
  plantillaOcId         String?
  enviadaAprobacionEn   DateTime?
  aprobadoPorId         String?
  aprobadoEn            DateTime?
  rechazadoPorId        String?
  rechazadoEn           DateTime?
  rechazadoMotivo       String?

  proveedor   Proveedor         @relation(fields: [proveedorId], references: [id])
  creadoPor   Usuario?          @relation("OcCreador", fields: [creadoPorId], references: [id])
  solicitante Usuario?          @relation("OcSolicitante", fields: [solicitanteId], references: [id])
  aprobadoPor Usuario?          @relation("OcAprobador", fields: [aprobadoPorId], references: [id])
  rechazadoPor Usuario?         @relation("OcRechazador", fields: [rechazadoPorId], references: [id])
  ordenTrabajo OrdenTrabajo?    @relation(fields: [ordenTrabajoId], references: [id])
  presupuesto  Presupuesto?     @relation(fields: [presupuestoId], references: [id])
  cliente      Cliente?         @relation(fields: [clienteId], references: [id])
  depositoDestinoDefault Deposito? @relation("OcDepositoDefault", fields: [depositoDestinoDefaultId], references: [id])
  plantillaOc  PlantillaOC?     @relation(fields: [plantillaOcId], references: [id])
  items       ItemOrdenCompra[]
  facturasCompra FacturaCompra[]
  eventos     EventoOrdenCompra[]
  notificaciones NotificacionUsuario[]

  @@index([estado])
  @@index([proveedorId])
  @@index([plantillaOcId])
  @@map("ordenes_compra")
}

model ItemOrdenCompra {
  id               String  @id @default(cuid())
  ordenCompraId    String
  inventarioId     String?
  concepto         String? // ítem de gasto (sin stock)
  descripcion      String
  cantidad         Int
  cantidadRecibida Int     @default(0)
  precioUnit       Float // precio neto unitario (post-bonificación o lista)
  precioLista      Float?
  bonificacionPct  Float   @default(0)
  subtotal         Float
  depositoDestinoId String?

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  inventario  Inventario? @relation(fields: [inventarioId], references: [id])
  depositoDestino Deposito? @relation("ItemOcDepositoDestino", fields: [depositoDestinoId], references: [id])
  itemsFacturaCompra ItemFacturaCompra[]

  @@map("items_orden_compra")
}

model EventoOrdenCompra {
  id            String       @id @default(cuid())
  ordenCompraId String
  tipo          TipoEventoOC
  fecha         DateTime     @default(now())
  usuarioId     String?
  referencia    String?
  payload       Json?

  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)
  usuario     Usuario?    @relation(fields: [usuarioId], references: [id])

  @@index([ordenCompraId, fecha])
  @@map("eventos_orden_compra")
}

model NotificacionUsuario {
  id            String             @id @default(cuid())
  usuarioId     String
  tipo          TipoNotificacionOC
  ordenCompraId String
  titulo        String
  mensaje       String
  href          String
  prioridad     String             @default("importante")
  creadaEn      DateTime           @default(now())
  leidaEn       DateTime?
  resueltaEn    DateTime?

  usuario     Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  ordenCompra OrdenCompra @relation(fields: [ordenCompraId], references: [id], onDelete: Cascade)

  @@index([usuarioId, resueltaEn])
  @@index([ordenCompraId, tipo])
  @@map("notificaciones_usuario")
}

// ============ FACTURAS DE COMPRA (Fase B) ============

model FacturaCompra {
  id                    String              @id @default(cuid())
  numero                String              @unique
  proveedorId           String
  tipo                  TipoFacturaCompra
  estado                EstadoFacturaCompra @default(BORRADOR)
  fecha                 DateTime
  fechaVencimiento      DateTime?
  puntoVenta            Int
  numeroComprobante     Int
  tipoComprobanteAfipId String?
  neto                  Float
  iva                   Float
  total                 Float
  moneda                String              @default("ARS")
  ordenCompraId         String?
  recepcionCompleta     Boolean             @default(false)
  fcSinRecepcion        Boolean             @default(false)
  notaFcSinRecepcion    String?
  notaMonedaOc          String?
  alertaFcPendienteEn   DateTime?
  cae                   String?
  caeVencimiento        DateTime?
  constatacionResultado String?
  constatadoEn          DateTime?
  constatacionObservaciones String?
  creadoPorId           String?
  registradaEn          DateTime?
  anuladaEn             DateTime?
  creadoEn              DateTime            @default(now())
  actualizadoEn         DateTime            @updatedAt

  proveedor           Proveedor            @relation(fields: [proveedorId], references: [id])
  ordenCompra         OrdenCompra?         @relation(fields: [ordenCompraId], references: [id])
  tipoComprobanteAfip TipoComprobanteAfip? @relation(fields: [tipoComprobanteAfipId], references: [id])
  creadoPor           Usuario?             @relation("FcCompraCreador", fields: [creadoPorId], references: [id])
  items               ItemFacturaCompra[]
  vencimientos        VencimientoPago[]
  pagosProveedor      PagoProveedor[]

  @@unique([proveedorId, puntoVenta, numeroComprobante])
  @@index([estado])
  @@index([proveedorId])
  @@index([fecha])
  @@index([tipo])
  @@map("facturas_compra")
}

model ItemFacturaCompra {
  id                String  @id @default(cuid())
  facturaCompraId   String
  descripcion       String
  concepto          String?
  cantidad          Float
  precioUnitario    Float
  precioLista       Float?
  bonificacionPct   Float   @default(0)
  alicuotaIvaPct    Float   @default(21)
  neto              Float
  iva               Float
  inventarioId      String?
  itemOrdenCompraId String?

  facturaCompra   FacturaCompra    @relation(fields: [facturaCompraId], references: [id], onDelete: Cascade)
  inventario      Inventario?      @relation(fields: [inventarioId], references: [id])
  itemOrdenCompra ItemOrdenCompra? @relation(fields: [itemOrdenCompraId], references: [id])

  @@map("items_factura_compra")
}

model VencimientoPago {
  id              String    @id @default(cuid())
  facturaCompraId String
  numeroCuota     Int       @default(1)
  fecha           DateTime
  monto           Float
  saldo           Float
  pagado          Boolean   @default(false)
  pagadoEn        DateTime?
  creadoEn        DateTime  @default(now())

  facturaCompra FacturaCompra              @relation(fields: [facturaCompraId], references: [id], onDelete: Cascade)
  imputaciones  ImputacionPagoProveedor[]

  @@unique([facturaCompraId, numeroCuota])
  @@index([fecha, pagado])
  @@map("vencimientos_pago")
}

// ============ PAGOS PROVEEDOR (Fase C) ============

model PagoProveedor {
  id                String              @id @default(cuid())
  proveedorId       String
  facturaCompraId   String?
  monto             Float
  moneda            String              @default("ARS")
  fecha             DateTime            @default(now())
  medio             MedioPago           @default(TRANSFERENCIA)
  cuentaTesoreriaId String?
  referencia        String?
  notas             String?
  estado            EstadoPagoProveedor @default(REGISTRADO)
  creadoPorId       String
  anuladoEn         DateTime?
  creadoEn          DateTime            @default(now())

  proveedor           Proveedor                  @relation(fields: [proveedorId], references: [id])
  facturaCompra       FacturaCompra?             @relation(fields: [facturaCompraId], references: [id])
  cuentaTesoreria     CuentaTesoreria?           @relation(fields: [cuentaTesoreriaId], references: [id])
  creadoPor           Usuario                    @relation("PagoProveedorCreador", fields: [creadoPorId], references: [id])
  imputaciones        ImputacionPagoProveedor[]
  chequeEmitido       ChequeEmitido?
  movimientoTesoreria MovimientoTesoreria?

  @@index([proveedorId, estado])
  @@index([fecha])
  @@index([cuentaTesoreriaId])
  @@map("pagos_proveedor")
}

model ImputacionPagoProveedor {
  id                String @id @default(cuid())
  pagoProveedorId   String
  vencimientoPagoId String
  monto             Float

  pagoProveedor   PagoProveedor   @relation(fields: [pagoProveedorId], references: [id], onDelete: Cascade)
  vencimientoPago VencimientoPago @relation(fields: [vencimientoPagoId], references: [id])

  @@index([vencimientoPagoId])
  @@map("imputaciones_pago_proveedor")
}

model ChequeEmitido {
  id                String              @id @default(cuid())
  pagoProveedorId   String?             @unique
  proveedorId       String
  numero            String
  banco             String              @default("")
  monto             Float
  fechaEmision      DateTime            @default(now())
  fechaDebito       DateTime?
  estado            EstadoChequeEmitido @default(EMITIDO)
  cuentaTesoreriaId String
  movimientoTesoreriaId String?         @unique
  creadoEn          DateTime            @default(now())
  actualizadoEn     DateTime            @updatedAt

  pagoProveedor       PagoProveedor?      @relation(fields: [pagoProveedorId], references: [id])
  proveedor           Proveedor           @relation(fields: [proveedorId], references: [id])
  cuentaTesoreria     CuentaTesoreria     @relation(fields: [cuentaTesoreriaId], references: [id])
  movimientoTesoreria MovimientoTesoreria? @relation(fields: [movimientoTesoreriaId], references: [id])

  @@unique([numero, banco])
  @@index([fechaDebito, estado])
  @@index([proveedorId, estado])
  @@map("cheques_emitidos")
}

model AlertaCompraDismiss {
  id           String   @id @default(cuid())
  alertKey     String
  dismissedById String
  dismissedEn  DateTime @default(now())

  dismissedBy Usuario @relation(fields: [dismissedById], references: [id])

  @@unique([alertKey, dismissedById])
  @@index([alertKey])
  @@map("alertas_compra_dismiss")
}

// ============ MANTENIMIENTO PREVENTIVO (Fase 7) ============

enum EstadoMantenimiento {
  PENDIENTE
  PROGRAMADO
  COMPLETADO
  VENCIDO
  CANCELADO
}

model PlanMantenimiento {
  id              String              @id @default(cuid())
  equipoId        String
  descripcion     String
  intervaloDias   Int                 @default(180)
  ultimoServicio  DateTime?
  proximoServicio DateTime?
  estado          EstadoMantenimiento @default(PENDIENTE)
  tecnicoId       String?
  notas           String?
  creadoEn        DateTime            @default(now())

  equipo  Equipo   @relation(fields: [equipoId], references: [id])
  tecnico Usuario? @relation(fields: [tecnicoId], references: [id])

  @@index([equipoId])
  @@index([proximoServicio])
  @@map("planes_mantenimiento")
}

// ============ TRACKING + MAPA (Fase 8) ============

model EventoTracking {
  id        String             @id @default(cuid())
  equipoId  String
  tipo      TipoEventoTracking
  lat       Float
  lng       Float
  direccion String?
  nota      String?
  fotoUrl   String?
  otId      String?
  usuarioId String?
  fecha     DateTime           @default(now())
  creadoEn  DateTime           @default(now())

  equipo  Equipo          @relation(fields: [equipoId], references: [id], onDelete: Cascade)
  ot      OrdenTrabajo?   @relation(fields: [otId], references: [id])
  usuario Usuario?        @relation(fields: [usuarioId], references: [id])

  @@index([equipoId])
  @@index([fecha])
  @@map("eventos_tracking")
}

// ============ CRM OMNICANAL (Fase 9) ============

enum TipoCanalIntegracion {
  WHATSAPP
  INSTAGRAM
  FACEBOOK
  EMAIL_IMAP
  EMAIL_GRAPH
  N8N
}

enum EstadoCanalIntegracion {
  NO_CONFIGURADO
  PENDIENTE
  CONECTADO
  ERROR
}

enum EstadoConversacionCRM {
  ABIERTA
  PENDIENTE
  CERRADA
}

enum DireccionMensajeCRM {
  ENTRANTE
  SALIENTE
}

model CanalIntegracion {
  id              String                 @id @default(cuid())
  tipo            TipoCanalIntegracion   @unique
  nombre          String
  activo          Boolean                @default(false)
  estado          EstadoCanalIntegracion @default(NO_CONFIGURADO)
  config          Json                   @default("{}")
  webhookUrl      String?
  pasoCompletado  Int                    @default(0)
  ultimoSync      DateTime?
  errorMensaje    String?
  creadoEn        DateTime               @default(now())
  actualizadoEn   DateTime               @updatedAt

  conversaciones ConversacionCRM[]

  @@map("canales_integracion")
}

model ConversacionCRM {
  id               String                @id @default(cuid())
  canalId          String
  externalId       String?
  estado           EstadoConversacionCRM @default(ABIERTA)
  asignadoId       String?
  clienteId        String?
  contactoNombre   String
  contactoHandle   String
  preview          String?
  etiquetas        String[]              @default([])
  sinLeer          Int                   @default(0)
  ultimoMensajeEn  DateTime              @default(now())
  creadoEn         DateTime              @default(now())

  canal    CanalIntegracion @relation(fields: [canalId], references: [id])
  cliente  Cliente?         @relation(fields: [clienteId], references: [id])
  asignado Usuario?         @relation(fields: [asignadoId], references: [id])
  mensajes MensajeCRM[]

  @@index([canalId])
  @@index([estado])
  @@index([ultimoMensajeEn])
  @@map("conversaciones_crm")
}

model MensajeCRM {
  id             String              @id @default(cuid())
  conversacionId String
  direccion      DireccionMensajeCRM
  tipo           String              @default("TEXTO")
  contenido      String
  adjuntoUrl     String?
  externalMsgId  String?
  usuarioId      String?
  fecha          DateTime            @default(now())

  conversacion ConversacionCRM @relation(fields: [conversacionId], references: [id], onDelete: Cascade)
  usuario      Usuario?        @relation(fields: [usuarioId], references: [id])

  @@index([conversacionId])
  @@map("mensajes_crm")
}

model CrmSnippet {
  id            String   @id @default(cuid())
  titulo        String
  cuerpo        String
  activo        Boolean  @default(true)
  orden         Int      @default(0)
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@index([activo, orden])
  @@map("crm_snippets")
}

// ============ CRM EMBUDO DE VENTAS ============

enum EtapaEmbudo {
  ENTRADA
  CONTACTO
  DOCUMENTACION
  PROPUESTA
  SEGUIMIENTO
  ANALISIS
  ENTREGA
  CIERRE
  PERDIDO
}

enum UrgenciaEmbudo {
  NORMAL
  URGENTE
}

enum TipoEventoEmbudo {
  MOVIMIENTO
  CREACION
  EDICION
  ELIMINACION
  REACTIVACION
}

model NegocioEmbudo {
  id                 String         @id @default(cuid())
  numero             Int            @unique
  nombre             String
  cliente            String
  clienteId          String?
  productoServicio   String?
  monto              Float          @default(0)
  vendedor           String
  urgencia           UrgenciaEmbudo @default(NORMAL)
  etapa              EtapaEmbudo    @default(ENTRADA)
  etapaDesde         DateTime       @default(now())
  proximaAccionFecha DateTime?
  presupuestoId      String?
  notas              String?
  datos              Json           @default("{}")
  activo             Boolean        @default(true)
  cerradoEn          DateTime?
  creadoEn           DateTime       @default(now())
  actualizadoEn      DateTime       @updatedAt

  clienteRel  Cliente?          @relation(fields: [clienteId], references: [id])
  presupuesto Presupuesto?      @relation(fields: [presupuestoId], references: [id])
  historial   HistorialEmbudo[]

  @@index([etapa])
  @@index([vendedor])
  @@map("negocios_embudo")
}

model HistorialEmbudo {
  id         String           @id @default(cuid())
  negocioId  String
  tipo       TipoEventoEmbudo @default(MOVIMIENTO)
  etapaDesde EtapaEmbudo?
  etapaHasta EtapaEmbudo?
  retroceso  Boolean          @default(false)
  datos      Json             @default("{}")
  notas      String?
  usuarioId  String?
  creadoEn   DateTime         @default(now())

  negocio NegocioEmbudo @relation(fields: [negocioId], references: [id], onDelete: Cascade)
  usuario Usuario?      @relation(fields: [usuarioId], references: [id])

  @@index([negocioId])
  @@index([tipo])
  @@index([creadoEn])
  @@map("historial_embudo")
}

// ============ CONFIGURACIÓN — CATÁLOGOS, NOTIFICACIONES, SEGURIDAD ============

model CategoriaInventarioCat {
  id       String   @id @default(cuid())
  codigo   String   @unique
  nombre   String
  orden    Int      @default(0)
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())

  @@map("categorias_inventario_cat")
}

model PoliticaSeguridad {
  id                  String   @id @default("default")
  longitudMinPassword Int      @default(8)
  requiereMayuscula    Boolean  @default(true)
  requiereNumero      Boolean  @default(true)
  requiereEspecial    Boolean  @default(false)
  expiracionDias      Int?
  maxIntentosLogin    Int      @default(5)
  bloqueoMinutos      Int      @default(15)
  maxIntentosIpHora   Int      @default(30)
  sesionMaxHoras      Int      @default(8)
  sesionEpoch         Int      @default(1)
  totpHabilitado      Boolean  @default(false)
  actualizadoEn       DateTime @updatedAt

  @@map("politica_seguridad")
}

model PlantillaNotificacion {
  id       String   @id @default(cuid())
  codigo   String   @unique
  nombre   String
  canal    String   @default("SISTEMA")
  asunto   String?
  cuerpo   String
  activo   Boolean  @default(true)
  creadoEn DateTime @default(now())

  reglas ReglaNotificacion[]

  @@map("plantillas_notificacion")
}

model ReglaNotificacion {
  id               String   @id @default(cuid())
  codigo           String   @unique
  nombre           String
  evento           String
  diasAnticipacion Int?
  activo           Boolean  @default(true)
  plantillaId      String?
  creadoEn         DateTime @default(now())

  plantilla PlantillaNotificacion? @relation(fields: [plantillaId], references: [id])

  @@map("reglas_notificacion")
}

model NotificacionLeida {
  usuarioId String
  clave     String
  leidaEn   DateTime @default(now())

  @@id([usuarioId, clave])
  @@map("notificaciones_leidas")
}
