DATABASE_URL="postgresql://admin:admin123@localhost:5432/ibiomedica_db"
NEXTAUTH_SECRET="your-secret-key-here"
# Puerto dev (3001 evita conflicto con otras apps en 3000)
PORT=3001
NEXTAUTH_URL="http://localhost:3001"

# ── Storage de archivos (fotos, PDFs, certificados AFIP) ──
# local: guarda en disco (./storage). s3: MinIO o S3 en producción (VPS).
STORAGE_DRIVER="local"
STORAGE_DIR="./storage"
# Producción (MinIO local del docker-compose):
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_BUCKET="ibiomedica"
S3_ACCESS_KEY_ID="admin"
S3_SECRET_ACCESS_KEY="admin123456"
S3_FORCE_PATH_STYLE="true"

# ── Cola de trabajos (worker BullMQ — Fase 4+) ──
REDIS_URL="redis://localhost:6379"

# ── CRM / Meta webhooks (Fase 9) ──
# Clave dedicada para cifrar credenciales de integraciones (AES-256-GCM)
# Obligatoria en producción — distinta de NEXTAUTH_SECRET
INTEGRATION_SECRET="otra-clave-larga-distinta-de-nextauth"
# Token compartido para verificación GET de Meta (fallback si no está en canal)
META_VERIFY_TOKEN="tu-verify-token-seguro"
# API key para endpoints /api/n8n/* (fallback si no está en canal N8N)
N8N_API_KEY="genera-una-clave-larga-aleatoria"
# Intervalo poll IMAP en ms (default 120000 = 2 min)
CRM_EMAIL_POLL_MS="120000"
# Intervalo poll Microsoft Graph en ms
CRM_GRAPH_POLL_MS="120000"

# ── Backup off-site (VPS cron 03:30) ──
# BACKUP_DIR="/var/backups/ibiomedica"
# Opción A — rsync a otro servidor
# BACKUP_OFFSITE_RSYNC_TARGET="deploy@backup.example.com:/var/backups/ibiomedica/"
# Opción B — AWS S3 (requiere aws cli en el VPS)
# BACKUP_OFFSITE_S3_BUCKET="mi-bucket-backups"
# BACKUP_OFFSITE_S3_PREFIX="ibiomedica/backups"

# ── Login rate limit (OWASP/CIS estándar) ──
LOGIN_MAX_ATTEMPTS="5"
LOGIN_LOCKOUT_MINUTES="15"
LOGIN_IP_MAX_HOURLY="30"

# ── Alertas de seguridad por email ──
# Destinatarios (coma-separados). Si vacío → emails de usuarios SUPERADMIN
ADMIN_NOTIFY_EMAIL="admin@ib.com"
# SMTP dedicado para alertas (opcional si ya tenés EMAIL_IMAP conectado)
SYSTEM_SMTP_HOST="smtp-mail.outlook.com"
SYSTEM_SMTP_PORT="587"
SYSTEM_SMTP_USER="alertas@tudominio.com"
SYSTEM_SMTP_PASSWORD="contraseña-de-aplicacion"
SYSTEM_SMTP_FROM_NAME="iBiomédica Alertas"
SYSTEM_SMTP_FROM_EMAIL="alertas@tudominio.com"

# ── Cobranzas: avisos de vencimiento ──
# Destinatarios (coma-separados). Default: guillermo@ y lucas@ib.com
COBRANZA_NOTIFY_EMAIL="guillermo@ib.com,lucas@ib.com"
# Intervalo del worker en ms (default 3600000 = 1 h)
COBRANZA_POLL_MS="3600000"
# Email recordatorio de pago al cliente (cuota vencida o N días antes)
COBRANZA_EMAIL_CLIENTE="true"
# Días antes del vencimiento para aviso al cliente (fallback si no hay regla cobranza.proximo)
COBRANZA_RECORDATORIO_DIAS="3"
# Secreto para POST /api/cron/* (cobranzas-vencimientos, ots-vencidas, presupuestos-vencidos)
CRON_SECRET=""

# ── Email factura al cliente post-emisión ──
# false / 0 / no desactiva el envío automático con PDF tras EMITIDA
FACTURA_EMAIL_CLIENTE="true"

# ── Email OT cerrada al cliente ──
OT_EMAIL_CLIENTE="true"

# ── Email presupuesto al cliente post-ENVIADO ──
PRESUPUESTO_EMAIL_CLIENTE="true"

# ── Alertas stock mínimo (admin) ──
# false desactiva; destinatarios opcionales (default ADMIN_NOTIFY_EMAIL)
STOCK_MINIMO_EMAIL="true"
# STOCK_MINIMO_NOTIFY_EMAIL="admin@ib.com,compras@ib.com"

# ── AFIP / facturación electrónica ──
# Token @afipsdk/afip.js (opcional según plan; vacío en homologación con CAE simulado)
AFIP_ACCESS_TOKEN=""
# Certificados (.crt/.key) se suben por emisor en Configuración → Emisores (storage S3/MinIO).
# Ambiente HOMOLOGACION vs PRODUCCION se define por emisor en BD, no por env.
# Worker cola: pm2 start npm --name worker-afip -- run worker:afip (requiere REDIS_URL)
